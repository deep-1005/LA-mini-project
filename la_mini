def to_gray(img):
    """
    Convert an RGB image (H x W x 3 array) to a greyscale image (H x W).

    Why these weights?
    Human eyes are most sensitive to green, less to red, barely to blue.
    The standard luminance formula weights each channel accordingly:
        Y = 0.299*R + 0.587*G + 0.114*B
    This gives a perceptually accurate brightness value for every pixel.

    If the image is already 2-D (greyscale), just return it as float.
    We work in float (not int) so we don't lose precision during maths.
    """
    if img.ndim == 3:                         # colour image has 3 channels
        return (0.299 * img[:, :, 0] +        # red channel
                0.587 * img[:, :, 1] +        # green channel
                0.114 * img[:, :, 2]          # blue channel
               ).astype(float)
    return img.astype(float)                  # already greyscale


def gray_to_rgb(arr):
    """
    Turn a 2-D greyscale array back into a displayable 3-channel image.

    Displays need R, G, B values.  For a greyscale image all three
    channels are identical, so we just stack the same 2-D array three times.

    np.clip makes sure no pixel value goes outside [0, 255] (valid byte range).
    np.stack(..., axis=2) creates a (H, W, 3) array.
    """
    g = np.clip(arr, 0, 255).astype(np.uint8)
    return np.stack([g, g, g], axis=2)


def apply_transform(img, M):
    """
    Apply a 2x2 linear transformation matrix M to every pixel position
    in the image, rotating/scaling around the image centre.

    Why do we need an offset?
    scipy's affine_transform maps output pixel positions BACK to input
    positions using the formula:
        input_pos = M @ output_pos + offset
    If offset = 0, the transformation happens around the top-left corner
    (pixel 0,0), which looks wrong.  We compute the offset so that the
    centre pixel stays in the centre:
        offset = center - M @ center

    For colour images we transform each R, G, B channel separately,
    then stack them back together.  cval=128 fills any empty border
    pixels with mid-grey.
    """
    center = np.array(img.shape[:2]) / 2.0    # (row_centre, col_centre)
    offset = center - M @ center              # correction so centre stays put

    if img.ndim == 3:
        # Process each colour channel independently
        channels = [
            affine_transform(img[:, :, c], M, offset=offset, cval=128)
            for c in range(3)                 # c = 0 (R), 1 (G), 2 (B)
        ]
        return np.stack(channels, axis=2).astype(np.uint8)

    # Greyscale — one channel only
    return affine_transform(img, M, offset=offset, cval=128).astype(np.uint8)


def recolor(original, gray_new, gray_old):
    """
    Re-apply the original colours after a greyscale mathematical operation.

    The linear-algebra steps (SVD, eigenanalysis, etc.) work on greyscale
    because colour would require 3 separate SVDs.  After computing the new
    greyscale brightness we want the colours back.

    Method: for every pixel compute the ratio  new_brightness / old_brightness
    and multiply EACH colour channel by that ratio.
    This scales the colour up or down proportionally, preserving the hue.

    np.clip(..., 1, None) prevents division-by-zero for very dark pixels.
    [:, :, np.newaxis] broadcasts the 2-D ratio onto all 3 colour channels.
    """
    if original.ndim == 3:
        ratio = gray_new / np.clip(gray_old, 1, None)
        return np.clip(original * ratio[:, :, np.newaxis], 0, 255).astype(np.uint8)
    return gray_to_rgb(gray_new)              # no colour to restore -> just greyscale


